# password-checking
Practice-based project to validate passwords using Python.  Includes checks for length, uppercase, lowercase, digits,  and special characters. Created for learning and experimenting  with conditional statements and string handling.
pwd = input("enter your password")
if len(pwd) < 4:  # if the password is less than 4 characters long, it is considered weak
    print("weak password")
elif len(pwd) < 8:  # if the password is between 4 and 8 characters long, it is considered medium
    print("medium password")
else:  # if the password is 8 characters or longer, it is considered strong
    print("strong password")

# application of password checking
passwords = {   
    "social media": "akshaydubey123",
    "email": "akshaydubey@2026",
    "bank": "akshay@88197",
    "gaming": "akshay@1234",
    "internet": "akshay8451981549",
    "phone": "84519"
}
app = input("enter the app you want to login: ")
password = input("enter your password: ")
if app in passwords:
    if passwords[app] == password:
        print("login successful")
    else:
        print("incorrect password")
else:
    print("app not found")
# forgetting password
forget_password = input("do you want to forget your password? (y/n): ")
if forget_password == "y":
    app = input("enter the app you want to forget the password for: ")
    if app in passwords:
        del passwords[app]
        print("password forgotten successfully")
    else:
        print("app not found")
